# Local development defaults — none of this is secret.
#
# docker-compose.yml falls back to these exact values when no .env exists,
# so creating one is OPTIONAL. Copy it only if you need to change something
# (usually because a port is already taken on your machine):
#
#   cp .env.example .env
#
# If you change the credentials, also update trino/catalog/iceberg.properties.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
NESSIE_PORT=19120
TRINO_PORT=8080
